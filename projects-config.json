      "id": "numerisation-des-tickets-de-tissus",
      "repository": "Scanner-de-ticket",
      "title": "Numérisation des tickets de tissus",
      "visible": true,
      "category": "javascript",
      "destination": "readme",
      "localPage": "",
      "publicUrl": "",
      "image": "https://res.cloudinary.com/dgrszi9wf/image/upload/v1701424796/Dragon/image/traveaux.gif",
      "imageMode": "legacy",
      "description": "",
      "languages": [
